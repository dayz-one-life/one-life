DATABASE_URL=postgres://onelife:onelife@localhost:5432/onelife

# Nitrado — single shared account token (single tenant). Which servers to ingest is
# driven by the `servers` table (active=true), NOT env: register a server by inserting
# its nitrado_service_id into `servers`. The ingest-worker sweeps all active servers.
NITRADO_TOKEN=

# Ingest (ADM + RPT)
INGEST_INTERVAL_SECONDS=60
ADM_BACKFILL_BUDGET=15
# RPT character mapping: how close (hours) a sighting must be to a character's last-seen to be
# the same character epoch (guards against charID reuse after a server wipe).
CHAR_STALE_HOURS=72
LOG_LEVEL=info

# projector
PROJECTOR_INTERVAL_SECONDS=30
PROJECTOR_BATCH_SIZE=500

# enforcer (death-ban) — SAFE DEFAULT is dry-run: logs intended bans, no Nitrado writes.
# Set ENFORCER_DRY_RUN=false only when you intend to apply real bans.
ENFORCER_DRY_RUN=true
ENFORCER_INTERVAL_SECONDS=300
BAN_DURATION_HOURS=24

# granter (token grants) — idempotent sweeps; verification, monthly, and referral tokens.
GRANTER_INTERVAL_SECONDS=300

# newsdesk (obituary generation) — sweeps qualified deaths lacking an obituary and writes each in
# the One Life voice via OpenRouter. SAFE DEFAULT is dry-run: obituaries are logged, not generated
# or stored (no OpenRouter credits spent). Set NEWSDESK_DRY_RUN=false to actually generate + write.
OPENROUTER_API_KEY=
NEWSDESK_MODEL=anthropic/claude-sonnet-5
NEWSDESK_DRY_RUN=true

# Birth notices (Fresh Spawns) — the newsdesk birth-notice pass is OFF until you set
# NEWSDESK_BIRTH_SINCE to an ISO-8601 go-live instant (e.g. 2026-07-18T00:00:00Z); from then it
# writes forward-only birth notices for qualified lives (still gated by NEWSDESK_DRY_RUN).
# Unset / empty / invalid ⇒ the pass stays off.
NEWSDESK_BIRTH_SINCE=

# Discord obituary notifier — posts a link to each published obituary into a Discord channel via an
# incoming webhook (Discord unfurls the page's OG card). Empty webhook = disabled. Respects
# NEWSDESK_DRY_RUN (dry-run logs the intended post, does not send). The webhook URL is a secret —
# keep the real value only in the host .env, never commit it.
DISCORD_OBITUARY_WEBHOOK_URL=
SITE_URL=https://dayzonelife.com
NEWSDESK_DISCORD_MAX_PER_TICK=10

# Article images (R5c). Generated via OpenRouter's image API; behind NEWSDESK_DRY_RUN like the prose.
NEWSDESK_IMAGE_MODEL=openai/gpt-5-image-mini
NEWSDESK_IMAGE_MODEL_FLAGSHIP=openai/gpt-5.4-image-2
NEWSDESK_IMAGE_QUALITY=low
# Images-only kill switch — set false to stop image generation without stopping articles.
NEWSDESK_IMAGES_ENABLED=true

# News features (R5d) — the Standing Dead + Long Form vertical. OPT-IN, and off in two independent
# ways: it does nothing unless NEWSDESK_NEWS_ENABLED is exactly "true" AND NEWSDESK_NEWS_SINCE is a
# valid ISO-8601 go-live instant. Unlike the other passes the subjects here are ALIVE and did not
# ask to be covered, so the default is silence. Still gated by NEWSDESK_DRY_RUN as well — note that
# NEWSDESK_DRY_RUN is the WORKER-GLOBAL gate, so the "dry-run for one interval" step below also
# silences obituary generation, birth notices, the Discord notifier and the image pass for that
# same interval. Benign (all four are idempotent sweeps that resume next tick, and the Discord
# notifier drains its backlog), but worth knowing before you flip it for a look at the news log.
#
# Until PR-C3 (news read-model + API + web) ships, pair NEWSDESK_NEWS_ENABLED=true with
# NEWSDESK_IMAGES_ENABLED=false: findImageTargets has no kind exclusion for "news", so a published
# news row is image-eligible the moment it publishes, but there is no web surface yet that can
# render a news hero image. Leaving images on pays ~$0.004/article (NEWSDESK_IMAGE_QUALITY=low)
# for a photo nothing displays.
#
# Go-live sequence: deploy with NEWSDESK_NEWS_ENABLED unset -> set it with NEWSDESK_DRY_RUN=true for
# one interval -> read the log and eyeball the selected subjects by hand -> set DRY_RUN=false.
#
# THE REAL PACE: NEWSDESK_NEWS_MAX_PER_TICK is a per-tick batch size on the
# NEWSDESK_INTERVAL_SECONDS loop (default 300s = 5 min) — not a rate limit — and news-tick.ts
# applies it PER ARM, once to the Standing Dead finder and once to the Long Form finder, so a
# single tick can publish up to 2x NEWSDESK_NEWS_MAX_PER_TICK articles. At the shipped defaults
# (MAX_PER_TICK=2, INTERVAL_SECONDS=300) a 7-subject Standing Dead backlog drains in
# ceil(7/2)=4 ticks, i.e. ~20 minutes — not the "over ~4 days" figure this feature's own spec
# (§13.2) once assumed. Recompute for your own numbers: ticks = ceil(backlog / MAX_PER_TICK);
# wall-clock = ticks * NEWSDESK_INTERVAL_SECONDS.
NEWSDESK_NEWS_ENABLED=
NEWSDESK_NEWS_SINCE=
# Per-ARM limit (see arithmetic above) — applied independently to Standing Dead and Long Form, not
# a combined cap across both.
NEWSDESK_NEWS_MAX_PER_TICK=2
# Comma-separated subject opt-out (honoured on request; the dev account belongs here first).
NEWSDESK_NEWS_SUPPRESSED_GAMERTAGS=

# Editorial desk: the secret that makes an unpublished draft visible at its real URL
# (GET /news/<slug>?preview=<token>). EMPTY = preview disabled entirely. Generate with:
#   openssl rand -hex 16
NEWS_PREVIEW_TOKEN=
# The Standing Dead: idle hours before a subject is eligible, the minimum playtime that makes a
# life worth reporting, and the absorbed-hit floor of the earned-coverage clause (a subject
# qualifies on EITHER a prior life OR this many hits — never on neither).
NEWSDESK_STANDING_DEAD_HOURS=72
NEWSDESK_STANDING_DEAD_MIN_PLAYTIME_SECONDS=1800
NEWSDESK_STANDING_DEAD_MIN_HITS=100
# The Long Form: two deaths join one clique only if EVERY pair is inside both thresholds. Do not
# widen these to make it fire more often — 300s/150m only admits dev-account noise.
NEWSDESK_LONGFORM_WINDOW_SECONDS=180
NEWSDESK_LONGFORM_RADIUS_METERS=100
# Discards a death whose last position fix is older than this — protection against stale fixes,
# since ten minutes of movement is roughly a kilometre against a 100 m radius.
NEWSDESK_LONGFORM_MAX_FIX_AGE_SECONDS=120

# notifier (player notifications) — sweeps for nine notification kinds (gamertag verified, tokens
# received/granted, ban applied/lifted, life qualified, survival milestone, obituary/birth-notice
# published), writes them to the durable `notifications` table, and delivers unread ones to
# subscribed browsers as Web Push. Two independent passes per tick, in their own try/catch blocks:
# a broken push pipeline can never stop generation. Full staged rollout: deploy/README.md.
#
# NOTIFIER_SINCE is the one to understand. Generation is OFF unless it parses as a date — unset,
# empty, or junk ⇒ zero drafts, no writes, and the worker logs "NOTIFIER_SINCE is unset". There is
# deliberately no epoch default: this table is an inbox for real people, and a silent default would
# announce every ban, death and article in the entire history of the platform to everyone at once.
# Set it ONCE to a go-live instant (e.g. 2026-07-20T00:00:00Z) to begin forward-only coverage.
# Every generator floors its query at max(NOTIFIER_SINCE, now - NOTIFIER_LOOKBACK_HOURS), so the
# window can never reach back before go-live no matter how large the lookback is.
NOTIFIER_SINCE=
# SAFE DEFAULT: dry-run. Generators run and log what they WOULD write; nothing is inserted and
# nothing is pushed. Only the exact string "false" turns it off — a blank or mis-cased value stays
# on the safe side rather than throwing at startup and crash-looping the unit.
NOTIFIER_DRY_RUN=true
# Sweep cadence. Both passes run once per interval.
NOTIFIER_INTERVAL_SECONDS=60
# Per-tick generator query window (see NOTIFIER_SINCE above). This is a bound on how far back each
# tick looks, NOT a delivery cap — it exists so a long-running worker doesn't re-scan all history
# every minute. It must comfortably exceed the worst-case lag between an event happening and its
# row landing (ingest -> projector), or a notification can age out of the window before it is
# generated. 48h is generous for a 60s sweep; shortening it is a false economy.
NOTIFIER_LOOKBACK_HOURS=48
# Kill switch for the PUSH pass only — generation and the in-app rail are unaffected, so turning
# this off stops phones buzzing while notifications keep accruing normally. Same lenient parse as
# NOTIFIER_DRY_RUN. Push is additionally off whenever the VAPID triple below is missing or invalid.
NOTIFIER_PUSH_ENABLED=true
# THE REAL PACE: NOTIFIER_PUSH_MAX_PER_TICK is a per-tick batch size on the
# NOTIFIER_INTERVAL_SECONDS loop, not a rate limit. At the shipped defaults (50 per tick, 60s) a
# 500-notification backlog drains in ceil(500/50) = 10 ticks, i.e. ~10 minutes. Recompute for your
# own numbers: ticks = ceil(backlog / MAX_PER_TICK); wall-clock = ticks * INTERVAL_SECONDS.
# Note that rows skipped for having no active subscription, or for being stale (below), still
# consume batch slots — a backlog of undeliverable rows drains at the same rate.
NOTIFIER_PUSH_MAX_PER_TICK=50
# A notification older than this is marked pushed WITHOUT being sent. This is what stops a user who
# enables push today from being blasted by yesterday's backlog; it also stops undeliverable rows
# from being reconsidered every tick forever.
NOTIFIER_PUSH_MAX_AGE_MINUTES=60
# VAPID key pair for Web Push. Generate once with `npx web-push generate-vapid-keys`. VAPID_SUBJECT
# must include its scheme (e.g. mailto:ops@dayzonelife.com) — web-push rejects a bare address.
# Missing or malformed values leave push OFF and log a warning; they never kill the worker.
# VAPID_PUBLIC_KEY must ALSO be readable by the onelife-api unit, which serves it at
# GET /push/vapid-key so browsers can subscribe. The PRIVATE key is notifier-only and must never
# reach the API or the web bundle.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=
# SITE_URL is required by the notifier's config schema (shared with the newsdesk block above) but
# is currently RESERVED/UNUSED by this worker — every notification href is a relative path. It is
# threaded through GeneratorDeps so an absolute-link kind can use it later; nothing reads it today.

# Testing
TEST_DATABASE_URL=postgres://onelife:onelife@localhost:5432/onelife_test
